      "boundElements": [],
      "updated": 1774538460541,
      "link": null,
      "locked": false,
      "text": "Cloud Definitions\n- Cloud computing: on-demand internet-delivered\nservices\n- Shared responsibility: provider + customer duties\n- Public cloud: provider-owned, multi-tenant\n- Private cloud: dedicated, high control\n- Hybrid cloud: integrated on-prem + cloud",
      "fontSize": 19.74602980840775,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 163,
      "containerId": null,
      "originalText": "Cloud Definitions\n- Cloud computing: on-demand internet-delivered services\n- Shared responsibility: provider + customer duties\n- Public cloud: provider-owned, multi-tenant\n- Private cloud: dedicated, high control\n- Hybrid cloud: integrated on-prem + cloud",
      "lineHeight": 1.25,
      "index": "a5",
      "frameId": null,
      "roundness": null,
      "autoResize": false
    },
