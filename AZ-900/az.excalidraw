      "versionNonce": 654260215,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773929023434,
      "link": null,
      "locked": false,
      "text": "Exam Decision Shortcuts\n1) Need OS-level control? -> VM (IaaS)\n2) Need web/API hosting fast without managing OS? -> App Service (PaaS)\n3) Triggered, stateless code with pay-per-use? -> Functions (Serverless)\n4) Containers without orchestrator? -> ACI | With orchestrator? -> AKS\n5) Private dedicated on-prem connectivity? -> ExpressRoute | Encrypted internet tunnel? -> VPN Gateway\n6) Data rarely accessed long-term? -> Archive tier | Frequent access? -> Hot tier\n7) Enforce allowed resource configs? -> Azure Policy | Control who can act? -> RBAC",
      "fontSize": 22,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 203,
      "containerId": null,
      "originalText": "Exam Decision Shortcuts\n1) Need OS-level control? -> VM (IaaS)\n2) Need web/API hosting fast without managing OS? -> App Service (PaaS)\n3) Triggered, stateless code with pay-per-use? -> Functions (Serverless)\n4) Containers without orchestrator? -> ACI | With orchestrator? -> AKS\n5) Private dedicated on-prem connectivity? -> ExpressRoute | Encrypted internet tunnel? -> VPN Gateway\n6) Data rarely accessed long-term? -> Archive tier | Frequent access? -> Hot tier\n7) Enforce allowed resource configs? -> Azure Policy | Control who can act? -> RBAC",
      "lineHeight": 1.25,
      "index": "aZ",
      "frameId": null,
      "roundness": null,
      "autoResize": true
    },
